### n8n – podstawowa konfiguracja

# Adres hosta, pod którym będzie dostępne n8n (dla Mikrusa i lokalnie)
N8N_HOST=your-domain-or-ip
N8N_PORT=5678
N8N_PROTOCOL=http

# Podstawowe uwierzytelnianie do panelu n8n
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me

# Klucz szyfrujący (w produkcji wygeneruj losowy, długi string)
N8N_ENCRYPTION_KEY=change-this-to-long-random-string

### Baza danych Postgres dla n8n

POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-me
POSTGRES_DB=n8n

DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=${POSTGRES_DB}
DB_POSTGRESDB_USER=${POSTGRES_USER}
DB_POSTGRESDB_PASSWORD=${POSTGRES_PASSWORD}

### Telegram bot

TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_URL=https://your-domain-or-ip/bot/webhook

# Owner chat ID (MASTER_CHAT_ID) – tylko ten użytkownik:
# - ma pełny dostęp do bota niezależnie od whitelisty,
# - może zarządzać whitelistą komendami /allow_here, /revoke_here, /allowed_list,
# - zawsze otrzymuje alerty stresowe.
MASTER_CHAT_ID=123456789

# Port HTTP wystawiany przez kontener bota (endpointy sterujące, np. /send-test)
TELEGRAM_BOT_HTTP_PORT=8000

# Ścieżka do pliku z zapisanymi subskrybentami (ID czatów)
TELEGRAM_BOT_SUBSCRIBERS_FILE=/app/data/subscribers.json

### Distributed Automation Gateway – Node Gateway & Biometric Proxy

# URL webhooka n8n, do którego Node Gateway wysyła zdarzenia (np. plany, decyzje)
N8N_WEBHOOK_URL=http://n8n:5678/webhook/ai-gateway

# Sekretny nagłówek wysyłany przez Node Gateway do webhooka n8n
N8N_WEBHOOK_SECRET=change-this-webhook-secret

# Maksymalny rozmiar notatki głosowej (w bajtach) dla kodowania Base64
VOICE_BASE64_MAX_BYTES=2000000

# Retencja rekordów processed w outbox (w godzinach)
OUTBOX_PROCESSED_TTL_HOURS=72
# Interwał pollera outbox (ms), rozmiar batcha, maks. liczba ponownych prób przed dead_letter
OUTBOX_POLL_INTERVAL_MS=5000
OUTBOX_BATCH_SIZE=10
OUTBOX_MAX_RETRIES=5

# Klucz do komunikacji między usługami (Node Gateway <-> Biometric Proxy)
INTERNAL_API_KEY=change-this-internal-api-key

# Dane logowania do Garmin Connect (używane przez Biometric Proxy)
GARMIN_EMAIL=your-garmin-email@example.com
GARMIN_PASSWORD=change-me-garmin-password

# Próg stresu, powyżej którego wysyłany jest impuls (domyślnie 70)
STRESS_ALERT_THRESHOLD=70

### Ogólne

TZ=Europe/Warsaw

# Gemini API (np. do przyszłych integracji / workflowów)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash-8b